OPENCLAW_FILE_BROWSER_HOST=127.0.0.1
OPENCLAW_FILE_BROWSER_PORT=1455
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_SERVICE_NAME=openclaw.service
OPENCLAW_FILE_BROWSER_SERVICE_NAME=local-dashboard-1455.service

# Core OpenClaw paths
OPENCLAW_FILE_BROWSER_HOME_DIR=/root
OPENCLAW_HOME_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_RESEARCH_MEMORY_DIR=/root/.openclaw/workspace/memory/research
OPENCLAW_SESSIONS_DIR=/root/.openclaw/agents/main/sessions

# File browser paths
OPENCLAW_FILE_BROWSER_UPLOADS_DIR=/root/local-dashboard/uploads
OPENCLAW_FILE_BROWSER_DASHBOARD_DIR=/root/local-dashboard
OPENCLAW_FILE_BROWSER_PROJECTS_DIR=/root/Projects
OPENCLAW_FILE_BROWSER_PROJECT_DIR=/root/Projects/deepfield-transmissions
OPENCLAW_INSTALL_DIR=/opt/openclaw
